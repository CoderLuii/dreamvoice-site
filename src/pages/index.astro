---
import LandingLayout from '../layouts/LandingLayout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<LandingLayout
  title="DreamVoice — AI Voice Companion for Discord"
  description="An AI that joins your Discord voice channel and actually talks with you. Never sit in an empty VC again."
  product="DreamVoice"
  image="/promo/dreamvoice/dreamvoice-og.png"
>
  <!-- Signature: vertical waveform thread -->
  <div class="dv-waveform-thread" aria-hidden="true">
    <svg viewBox="0 0 40 2000" preserveAspectRatio="none" class="dv-thread-svg">
      <path d="M20,0 Q30,50 20,100 Q10,150 20,200 Q30,250 20,300 Q10,350 20,400 Q30,450 20,500 Q10,550 20,600 Q30,650 20,700 Q10,750 20,800 Q30,850 20,900 Q10,950 20,1000 Q30,1050 20,1100 Q10,1150 20,1200 Q30,1250 20,1300 Q10,1350 20,1400 Q30,1450 20,1500 Q10,1550 20,1600 Q30,1650 20,1700 Q10,1750 20,1800 Q30,1850 20,1900 Q10,1950 20,2000" fill="none" stroke="url(#dv-thread-grad)" stroke-width="2" opacity="0.3"/>
      <defs>
        <linearGradient id="dv-thread-grad" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#3b82f6" stop-opacity="0"/>
          <stop offset="10%" stop-color="#3b82f6" stop-opacity="0.4"/>
          <stop offset="50%" stop-color="#7c3aed" stop-opacity="0.4"/>
          <stop offset="90%" stop-color="#3b82f6" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="#3b82f6" stop-opacity="0"/>
        </linearGradient>
      </defs>
    </svg>
  </div>

  <!-- Hero: Full viewport with waveform + chat bubbles -->
  <section class="relative overflow-hidden flex items-center justify-center px-6 dv-hero">
    <div class="gradient-mesh"></div>

    <!-- Voice waveform SVG background -->
    <div class="dv-hero-waveform" aria-hidden="true">
      <svg viewBox="0 0 800 200" preserveAspectRatio="none">
        <defs>
          <linearGradient id="dv-wave-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#3b82f6" stop-opacity="0.1"/>
            <stop offset="50%" stop-color="#7c3aed" stop-opacity="0.3"/>
            <stop offset="100%" stop-color="#3b82f6" stop-opacity="0.1"/>
          </linearGradient>
        </defs>
        <path class="dv-wave-path" d="M0,100 Q50,40 100,100 Q150,160 200,100 Q250,40 300,100 Q350,160 400,100 Q450,40 500,100 Q550,160 600,100 Q650,40 700,100 Q750,160 800,100" fill="none" stroke="url(#dv-wave-grad)" stroke-width="3"/>
        <path class="dv-wave-path dv-wave-2" d="M0,100 Q50,60 100,100 Q150,140 200,100 Q250,60 300,100 Q350,140 400,100 Q450,60 500,100 Q550,140 600,100 Q650,60 700,100 Q750,140 800,100" fill="none" stroke="url(#dv-wave-grad)" stroke-width="2"/>
      </svg>
    </div>

    <!-- Floating chat bubbles -->
    <div class="dv-bubble dv-bubble-left">
      <span>Hey, anyone here?</span>
    </div>
    <div class="dv-bubble dv-bubble-right">
      <span>I'm always here ✨</span>
    </div>

    <div class="text-center relative z-10 max-w-3xl mx-auto dv-hero-content">
      <img src="/promo/dreamvoice/logo.png" alt="DreamVoice logo" width="120" height="120" class="mx-auto mb-6 rounded-full" style="filter: drop-shadow(0 0 30px rgba(59, 130, 246, 0.3));" />
      <span class="section-label">AI Voice Bot for Discord</span>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight mb-6 gradient-text hero-glow">DreamVoice</h1>
      <p class="text-lg md:text-xl mb-10 max-w-xl mx-auto" style="color: var(--text-muted);">
        <span class="typewriter">An AI that joins your Discord voice channel and actually talks with you. Never sit in an empty VC again.</span>
      </p>
      <div class="flex items-center justify-center gap-4 flex-wrap">
        <a href="#waitlist" class="btn-glow inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-semibold text-sm active:scale-[0.98]" style="background: linear-gradient(135deg, #3b82f6, #7c3aed); color: #fff;">
          Claim Your Spot
        </a>
        <a href="#features" class="inline-block px-7 py-3.5 rounded-full font-semibold text-sm ring-1 ring-white/[0.12] transition-all duration-700 active:scale-[0.98]" style="color: var(--text);">
          Learn More
        </a>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Problem: Chat-style alternating cards -->
  <section class="px-6 py-20 md:py-28 section-glow">
    <div class="max-w-3xl mx-auto fade-in reveal-left">
      <span class="section-label">The Problem</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center section-heading">Discord voice channels are empty too often</h2>
      <div class="dv-chat-stack">
        <div class="dv-chat-msg dv-chat-left stagger-card">
          <div class="glass-enhanced glow-hover glow-reveal">
            <div class="glass-inner p-6">
              <div class="mb-3"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg></div>
              <h3 class="font-semibold mb-2">Dead Voice Channels</h3>
              <p class="text-sm" style="color: var(--text-muted);">You hop into VC and nobody's there. You leave. Everyone does the same thing. The channel stays empty.</p>
            </div>
          </div>
        </div>
        <div class="dv-chat-msg dv-chat-right stagger-card">
          <div class="glass-enhanced glow-hover glow-reveal">
            <div class="glass-inner p-6">
              <div class="mb-3"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></div>
              <h3 class="font-semibold mb-2">Odd Hours, No One Online</h3>
              <p class="text-sm" style="color: var(--text-muted);">Late night, early morning, different time zones. Your friends aren't always around when you want to talk.</p>
            </div>
          </div>
        </div>
        <div class="dv-chat-msg dv-chat-left stagger-card">
          <div class="glass-enhanced glow-hover glow-reveal">
            <div class="glass-inner p-6">
              <div class="mb-3"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg></div>
              <h3 class="font-semibold mb-2">Servers Lose Members</h3>
              <p class="text-sm" style="color: var(--text-muted);">When voice channels feel dead, people stop coming back. Activity drops, members leave, the community fades.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Solution: Single column feature cards -->
  <section id="features" class="px-6 py-20 md:py-28 section-glow section-glow-right">
    <div class="max-w-3xl mx-auto fade-in reveal-scale">
      <span class="section-label">The Solution</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-6 text-center section-heading">An AI that's always in your voice channel</h2>
      <p class="text-lg mb-12 text-center" style="color: var(--text-muted);">DreamVoice joins your Discord VC and talks naturally. It remembers context, matches your server's vibe, and keeps the conversation going.</p>
      <div class="dv-feature-stack">
        <div class="dv-feature-row stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-6 flex items-start gap-5">
              <div class="flex-shrink-0 mt-1"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></div>
              <div>
                <h3 class="font-semibold mb-2">Real Voice Conversation</h3>
                <p class="text-sm" style="color: var(--text-muted);">Not text to speech. Actual natural voice conversation in your Discord voice channel. Talk, listen, respond.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dv-feature-row stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-6 flex items-start gap-5">
              <div class="flex-shrink-0 mt-1"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg></div>
              <div>
                <h3 class="font-semibold mb-2">Always Online</h3>
                <p class="text-sm" style="color: var(--text-muted);">DreamVoice is there 24/7. No matter what time you hop in, someone's already in VC waiting to chat.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dv-feature-row stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-6 flex items-start gap-5">
              <div class="flex-shrink-0 mt-1"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M9.5 2A5.5 5.5 0 0 0 4 7.5c0 1.4.5 2.7 1.4 3.7L4 14l2.5-.5c1 .9 2.3 1.5 3.7 1.5h.1A5.5 5.5 0 0 0 14 9.5V9a5.5 5.5 0 0 0-4-5.2"/><path d="M14.5 2A5.5 5.5 0 0 1 20 7.5c0 1.4-.5 2.7-1.4 3.7L20 14l-2.5-.5c-1 .9-2.3 1.5-3.7 1.5"/></svg></div>
              <div>
                <h3 class="font-semibold mb-2">Adapts to Your Server</h3>
                <p class="text-sm" style="color: var(--text-muted);">It learns your server's culture, inside jokes, and communication style. It feels like a member, not a bot.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="dv-feature-row stagger-card">
          <div class="glass-enhanced glow-hover">
            <div class="glass-inner p-6 flex items-start gap-5">
              <div class="flex-shrink-0 mt-1"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
              <div>
                <h3 class="font-semibold mb-2">Group Conversations</h3>
                <p class="text-sm" style="color: var(--text-muted);">Works in multi-person voice chats too. Jumps in when relevant, listens when it should, never interrupts awkwardly.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="px-6 py-12">
    <p class="pull-quote fade-in">"Never sit in an empty VC again."</p>
  </section>

  <div class="shimmer-divider"></div>

  <!-- FAQ: Accordion -->
  <section class="px-6 py-20 md:py-28">
    <div class="max-w-3xl mx-auto fade-in reveal-fade">
      <span class="section-label">FAQ</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Common questions</h2>
      <div class="dv-accordion">
        <details class="dv-accordion-item glass-enhanced stagger-card">
          <summary class="glass-inner p-6 cursor-pointer font-semibold flex items-center justify-between">
            Is DreamVoice free?
            <span class="dv-accordion-icon">+</span>
          </summary>
          <div class="px-6 pb-6 text-sm" style="color: var(--text-muted);">We'll have a free tier with limited voice minutes and a premium plan for unlimited access. Join the waitlist to get early access pricing.</div>
        </details>
        <details class="dv-accordion-item glass-enhanced stagger-card">
          <summary class="glass-inner p-6 cursor-pointer font-semibold flex items-center justify-between">
            How does it sound?
            <span class="dv-accordion-icon">+</span>
          </summary>
          <div class="px-6 pb-6 text-sm" style="color: var(--text-muted);">Natural and conversational. Not robotic. We use the latest voice AI models to make it feel like talking to a real person.</div>
        </details>
        <details class="dv-accordion-item glass-enhanced stagger-card">
          <summary class="glass-inner p-6 cursor-pointer font-semibold flex items-center justify-between">
            When does it launch?
            <span class="dv-accordion-icon">+</span>
          </summary>
          <div class="px-6 pb-6 text-sm" style="color: var(--text-muted);">We're building now. Join the waitlist to be first in line when we open beta access.</div>
        </details>
        <details class="dv-accordion-item glass-enhanced stagger-card">
          <summary class="glass-inner p-6 cursor-pointer font-semibold flex items-center justify-between">
            Can I customize the personality?
            <span class="dv-accordion-icon">+</span>
          </summary>
          <div class="px-6 pb-6 text-sm" style="color: var(--text-muted);">Yes. Choose from different personality styles or create your own custom persona for your server.</div>
        </details>
      </div>
    </div>
  </section>

  <div class="shimmer-divider"></div>

  <!-- Waitlist -->
  <section id="waitlist" class="px-6 py-20 md:py-28 waitlist-glow">
    <div class="max-w-2xl mx-auto text-center fade-in reveal-scale">
      <span class="section-label">Invite-Only Beta</span>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Don't miss early access</h2>
      <p class="text-base mb-10" style="color: var(--text-muted);">Spots are limited for the invite-only beta. Claim yours and help shape the future of AI voice companions.</p>
      <div class="flex flex-wrap items-center justify-center gap-3 mb-8 text-xs" style="color: var(--text-muted);">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Early access pricing
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
          Priority onboarding
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full ring-1 ring-white/[0.08]">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          Shape the product
        </span>
      </div>
      <WaitlistForm product="dreamvoice" />
    </div>
  </section>

  <!-- Cross links -->
  <section class="px-6 py-16">
    <div class="max-w-4xl mx-auto fade-in">
      <p class="text-center text-sm font-medium mb-6" style="color: var(--text-muted);">Also check out</p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="https://dubvox.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Dubvox</a>
        <a href="https://jyko.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Jyko</a>
        <a href="https://pryz.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Pryz</a>
        <a href="https://sacris.coderluii.dev" class="px-5 py-2.5 rounded-full text-sm font-medium ring-1 ring-white/[0.08] transition-all duration-300 hover:ring-white/[0.2] hover:no-underline" style="color: var(--text-muted);">Sacris</a>
      </div>
    </div>
  </section>
</LandingLayout>

<style>
  /* Hero: full viewport */
  .dv-hero {
    min-height: 100vh;
    padding-top: 8rem;
    padding-bottom: 4rem;
  }

  /* Voice waveform behind hero */
  .dv-hero-waveform {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .dv-hero-waveform svg {
    width: 100%;
    max-width: 800px;
    height: 200px;
  }
  .dv-wave-path {
    animation: dv-wave-pulse 4s ease-in-out infinite;
  }
  .dv-wave-2 {
    animation-delay: -2s;
    opacity: 0.5;
  }
  @keyframes dv-wave-pulse {
    0%, 100% { d: path("M0,100 Q50,40 100,100 Q150,160 200,100 Q250,40 300,100 Q350,160 400,100 Q450,40 500,100 Q550,160 600,100 Q650,40 700,100 Q750,160 800,100"); }
    50% { d: path("M0,100 Q50,70 100,100 Q150,130 200,100 Q250,70 300,100 Q350,130 400,100 Q450,70 500,100 Q550,130 600,100 Q650,70 700,100 Q750,130 800,100"); }
  }

  /* Chat bubbles */
  .dv-bubble {
    position: absolute;
    z-index: 5;
    padding: 12px 20px;
    font-size: 14px;
    border-radius: 16px;
    opacity: 0;
    max-width: 220px;
  }
  .dv-bubble-left {
    left: 8%;
    top: 35%;
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: 16px 16px 16px 4px;
    color: #93c5fd;
    animation: dv-bubble-in-left 0.8s cubic-bezier(0.32, 0.72, 0, 1) 0.3s forwards;
  }
  .dv-bubble-right {
    right: 8%;
    top: 45%;
    background: rgba(124, 58, 237, 0.12);
    border: 1px solid rgba(124, 58, 237, 0.25);
    border-radius: 16px 16px 4px 16px;
    color: #c4b5fd;
    animation: dv-bubble-in-right 0.8s cubic-bezier(0.32, 0.72, 0, 1) 1.3s forwards;
  }
  @keyframes dv-bubble-in-left {
    from { opacity: 0; transform: translateX(-40px) translateY(10px); }
    to { opacity: 1; transform: translateX(0) translateY(0); }
  }
  @keyframes dv-bubble-in-right {
    from { opacity: 0; transform: translateX(40px) translateY(10px); }
    to { opacity: 1; transform: translateX(0) translateY(0); }
  }

  /* Hero content delayed entrance */
  .dv-hero-content {
    opacity: 0;
    animation: dv-content-in 1s cubic-bezier(0.32, 0.72, 0, 1) 1.8s forwards;
  }
  @keyframes dv-content-in {
    from { opacity: 0; transform: translateY(20px); filter: blur(8px); }
    to { opacity: 1; transform: translateY(0); filter: blur(0); }
  }

  /* Chat-style alternating cards */
  .dv-chat-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .dv-chat-msg {
    max-width: 80%;
  }
  .dv-chat-left {
    align-self: flex-start;
  }
  .dv-chat-right {
    align-self: flex-end;
  }

  /* Feature stack */
  .dv-feature-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Accordion */
  .dv-accordion {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .dv-accordion-item summary {
    list-style: none;
  }
  .dv-accordion-item summary::-webkit-details-marker {
    display: none;
  }
  .dv-accordion-icon {
    font-size: 1.25rem;
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    color: var(--text-muted);
  }
  .dv-accordion-item[open] .dv-accordion-icon {
    transform: rotate(45deg);
  }
  .dv-accordion-item[open] summary {
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: calc(1.25rem - 1px) calc(1.25rem - 1px) 0 0;
  }

  /* Waveform thread */
  .dv-waveform-thread {
    position: fixed;
    left: 2rem;
    top: 0;
    bottom: 0;
    width: 40px;
    z-index: 5;
    pointer-events: none;
    opacity: 0.4;
  }
  .dv-thread-svg {
    width: 100%;
    height: 100%;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .dv-bubble { display: none; }
    .dv-waveform-thread { display: none; }
    .dv-chat-msg { max-width: 95%; }
    .dv-hero { min-height: 90vh; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .dv-bubble-left, .dv-bubble-right { animation: none; opacity: 1; }
    .dv-hero-content { animation: none; opacity: 1; }
    .dv-wave-path { animation: none; }
  }

  html.landing-boot .dv-hero-waveform,
  html.landing-boot .dv-bubble-left,
  html.landing-boot .dv-bubble-right,
  html.landing-boot .dv-hero-content,
  html.landing-boot .dv-wave-path {
    animation-play-state: paused;
  }

  html.landing-boot .dv-hero-waveform,
  html.landing-boot .dv-bubble-left,
  html.landing-boot .dv-bubble-right,
  html.landing-boot .dv-hero-content {
    opacity: 0 !important;
  }
</style>
